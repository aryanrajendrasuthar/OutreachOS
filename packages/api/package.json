{
  "name": "@outreachos/api",
  "version": "1.0.0",
  "private": true,
  "description": "Express API server for OutreachOS",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@outreachos/shared": "*",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.43.0",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^1.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
