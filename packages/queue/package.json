{
  "name": "@outreachos/queue",
  "version": "1.0.0",
  "private": true,
  "description": "BullMQ job definitions and workers for OutreachOS",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@outreachos/ai": "*",
    "@outreachos/automation": "*",
    "@outreachos/shared": "*",
    "bullmq": "^5.7.0",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.0",
    "ioredis": "^5.3.0",
    "pino": "^9.1.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
