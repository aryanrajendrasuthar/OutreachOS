# ============================================================
# OutreachOS — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit the actual .env file.
# ============================================================

# App
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash) — get from upstash.com
REDIS_URL=
REDIS_TOKEN=

# Encryption — generate with: openssl rand -base64 32
# Must be a 256-bit (32-byte) base64-encoded random key
ENCRYPTION_KEY=

# Anthropic Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=

# Resend (email) — get from resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@outreachos.com

# Security
# Generate with: openssl rand -base64 64
JWT_SECRET=
SESSION_SECRET=

# Monitoring — get from sentry.io (optional but recommended for production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Database — Supabase Postgres connection string (for Drizzle migrations)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# E2E Tests (only needed for Playwright test runs)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
